	"author": {
		"name": "Ewan 'Clubwho' Lyon"
	},
	"repository": "https://github.com/nodecg/nodecg.git",
	"type": "module",
	"scripts": {
		"build": "pnpm run \"/^build:.*/\"",
		"build:browser": "vite build",
		"build:extensions": "tsdown",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"format": "oxfmt",
		"schema-types": "trash src/types/schemas && nodecg schema-types -o ./src/types",
		"start": "nodecg start",
		"watch": "pnpm run \"/^watch:.*/\"",
		"watch:browser": "vite",
		"watch:extensions": "tsdown -w",
		"type-check:browser": "tsgo -p tsconfig.browser.json --noEmit",
		"type-check:extensions": "tsgo -p tsconfig.extensions.json --noEmit"
	},
	"dependencies": {
		"@base-ui/react": "^1.6.0",
		"@craftjs/core": "^0.2.12",
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/modifiers": "^9.0.0",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@emotion/react": "^11.14.0",
		"@emotion/styled": "^11.14.1",
		"@ffprobe-installer/ffprobe": "^2.1.2",
		"@gsap/react": "^2.1.2",
		"@mui/icons-material": "^9.1.1",
		"@mui/lab": "9.0.0-beta.5",
		"@mui/material": "^9.1.2",
		"@mui/x-tree-view": "^9.7.0",
		"@nodecg/react-hooks": "^1.0.3",
		"@rive-app/react-canvas": "^4.29.3",
		"@uidotdev/usehooks": "^2.4.1",
		"date-fns": "^4.4.0",
		"fast-deep-equal": "^3.1.3",
		"gsap": "^3.15.0",
		"nodecg": "^2.6.4",
		"obs-websocket-js": "^5.0.8",
		"osc": "^2.4.5",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-markdown": "^10.1.0",
		"react-mosaic-component": "7.0.0-beta0",
		"react-router": "^8.0.1",
		"react-window": "^2.2.7",
		"remark-github-alerts": "^0.1.1",
		"underscore": "^1.13.8",
		"ws": "^8.21.0",
		"zod": "^4.4.3",
		"zustand": "^5.0.14"
	},
	"devDependencies": {
		"@babel/core": "^8.0.1",
		"@rolldown/plugin-babel": "^0.2.3",
		"@types/node": "^26.0.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@types/styled-components": "^5.1.36",
		"@types/underscore": "^1.13.0",
		"@types/ws": "^8.18.1",
		"@vitejs/plugin-react": "^6.0.3",
		"babel-plugin-react-compiler": "1.0.0",
		"oxfmt": "^0.56.0",
		"oxlint": "^1.71.0",
		"oxlint-tsgolint": "^0.23.0",
		"tsdown": "^0.22.3",
		"typescript": "7.0.1-rc",
		"vite": "^8.1.0",
		"vite-plugin-html": "^3.2.2",
		"vite-plugin-nodecg": "link:..\\vite-plugin-nodecg",
		"vite-plugin-svgr": "^5.2.0",
		"zx": "^8.8.5"
	},
	"packageManager": "pnpm@11.9.0",
	"nodecg": {
